<div class="container">
  <%= render 'shared/main_nav' %>

  <h1>Edit Section</h1>

  <%= link_to "← Back to Section", @section, class: "back-link" %>

  <div class="card">
    <%= form_with model: @section, local: true do |form| %>
      <% if @section.errors.any? %>
        <div class="error-messages">
          <h4><%= pluralize(@section.errors.count, "error") %> prohibited this section from being saved:</h4>
          <ul>
            <% @section.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="field">
        <%= form.label :name %>
        <%= form.text_field :name, required: true %>
      </div>

      <%= render 'shared/namespace_field', form: form %>

      <div class="field">
        <%= form.label :prompt %>
        <%= form.text_area :prompt %>
      </div>

      <div class="actions">
        <%= form.submit "Update Section" %>
      </div>
    <% end %>
  </div>

  <% if @section.questions.any? %>
    <div class="card">
      <h3>Questions in this Section</h3>
      <% questions = @section.questions.to_a %>
      <% questions.each_with_index do |question, idx| %>
        <div class="ordered-list-item">
          <div class="ordered-list-item-content">
            <span><%= link_to question.name, question_path(question) %></span>
            <span style="color: var(--gray-500); font-size: 0.875rem; margin-left: 0.5rem;">
              (<%= question.question_type %>)
            </span>
          </div>
          <div class="ordered-list-item-actions">
            <div class="move-controls">
              <% if idx > 0 %>
                <%= link_to "↑", move_question_up_section_path(@section, question_id: question.id),
                    data: { "turbo-method": :patch }, class: "btn-move", title: "Move up" %>
              <% end %>
              <% if idx < questions.length - 1 %>
                <%= link_to "↓", move_question_down_section_path(@section, question_id: question.id),
                    data: { "turbo-method": :patch }, class: "btn-move", title: "Move down" %>
              <% end %>
            </div>
            <%= link_to "✕", remove_question_section_path(@section, question_id: question.id),
                data: { "turbo-method": :patch, confirm: "Remove this question from the section?" },
                style: "color: var(--error); font-size: 1.25rem; font-weight: bold; text-decoration: none;",
                title: "Remove question" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="card">
    <div style="text-align: center;">
      <%= link_to "Delete Section", soft_delete_section_path(@section),
          data: { "turbo-method": :patch, confirm: "Are you sure you want to delete this section? This action cannot be undone." },
          class: "btn",
          style: "background-color: var(--error); color: var(--white);" %>
    </div>
  </div>
</div>